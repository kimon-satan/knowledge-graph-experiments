{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Paragraphs",
  "type": "object",
  "required": ["paragraphs"],
  "additionalProperties": false,
  "properties": {
    "paragraphs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
